# Sensitive files
deploy.mk
.env.development
.env.production

# Editor files
*.swp

# Python build files
__pycache__/
*.py[cod]
*$py.class

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# gatsby files
.cache/
public

# Generated content (hydrated from CONTENT_DIR/*.md by scripts/hydrate.mjs)
_generated/

# Optional local clone of the content repo (default CONTENT_DIR)
/content/

# Mac files
.DS_Store
.gstack/
